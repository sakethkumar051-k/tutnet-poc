# ── Core (required) ────────────────────────────────────────────────────
PORT=5001
MONGODB_URI=mongodb://localhost:27017/tutnet
JWT_SECRET=change-me-to-a-long-random-string
NODE_ENV=development

# ── Admin bootstrap (required for creating first admin) ────────────────
ADMIN_SECRET=change-me-for-admin-signup-gate

# ── OAuth (required if you want Google sign-in) ────────────────────────
# Get these from https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client IDs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# The redirect URI Google will send users back to after sign-in.
# It MUST match an "Authorized redirect URI" registered in Google Cloud Console exactly.
#   Local dev:  http://localhost:5001/api/auth/google/callback
#   Production: https://<your-backend-host>/api/auth/google/callback
# If GOOGLE_CALLBACK_URL is unset, the server derives it from SERVER_URL below.
GOOGLE_CALLBACK_URL=
# Public URL of this backend (used as a fallback to derive GOOGLE_CALLBACK_URL).
# Example: https://tutnet-1.onrender.com
SERVER_URL=
# Session secret for passport session store
SESSION_SECRET=change-me-to-another-long-random-string

# ── Razorpay payments ──────────────────────────────────────────────────
# Test keys (rzp_test_*) are free and don't require KYC.
# Live keys (rzp_live_*) require business verification.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret is YOUR OWN string you type when adding a webhook in dashboard.
# Leave empty during development if you're not testing webhook-driven flows.
RAZORPAY_WEBHOOK_SECRET=

# PAYMENT_MODE: 'mock' | 'test' | 'live'
#   mock = bypass Razorpay entirely, every order auto-succeeds (local dev)
#   test = hit real Razorpay test API (use rzp_test_* keys)
#   live = hit real Razorpay production API (use rzp_live_* keys + full KYC)
PAYMENT_MODE=test

# PAYOUT_MODE: 'mock' | 'razorpayx'
#   mock = log to PayoutLedger only, no actual money movement (needed until RazorpayX is live)
#   razorpayx = call RazorpayX Payouts API (requires current account + separate onboarding)
PAYOUT_MODE=mock

# ── Notifications (optional) ───────────────────────────────────────────
# Email reminders (24h / 1h before session)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Tutnet <noreply@tutnet.in>

# FCM push notifications (mobile)
FCM_SERVER_KEY=

# ── Proxy phone (optional, for masked call feature) ────────────────────
# Exotel / Knowlarity / MSG91 Voice — pick one
EXOTEL_SID=
EXOTEL_TOKEN=
EXOTEL_SUBDOMAIN=

# ── Client URL (used for emails / absolute links) ──────────────────────
CLIENT_URL=http://localhost:5173
